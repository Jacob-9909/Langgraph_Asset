# OpenAI (examples/02_llm_messages_graph.py)
OPENAI_API_KEY=your-key-here

# Google Gemini — examples/03_quickstart_calculator_graph_api.py (둘 중 하나)
GOOGLE_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# examples/04_user_asset_policy_multi_agent_hitl.py — Postgres·검색 키 등 (.env 로드 항목은 langgraph_bootstrap 참고)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/langgraph
#
# 04 리서치: 네이버 검색 API (웹문서 webkr) — https://developers.naver.com/products/service-api/search/search
# NAVER_CLIENT_ID=...
# NAVER_CLIENT_SECRET=...
#
# 04 거시 금리 리서치: Tavily — https://tavily.com
# TAVILY_API_KEY=tvly-...
#
# 04 세법 맥락: 국가법령정보 국세청 법령해석 목록 API — https://open.law.go.kr
# LAW_GO_KR_OC=...   # 신청 후 발급 OC (target=ntsCgmExpc, live 는 type=XML · 루트 CgmExpc)
# OC 가 비어 있으면 자동으로 mock JSON 을 씁니다. 실제 응답 수신 후에도 mock 을 쓰려면:
# NTS_LAW_FORCE_MOCK=1

# Langfuse 관측 — https://langfuse.com/docs/integrations/langchain
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# (구식) LANGFUSE_HOST=...  # LANGFUSE_BASE_URL 과 동일 역할
