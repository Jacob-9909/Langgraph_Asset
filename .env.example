# OpenAI (examples/02_llm_messages_graph.py)
OPENAI_API_KEY=your-key-here

# Google Gemini — examples/03_quickstart_calculator_graph_api.py (둘 중 하나)
GOOGLE_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# examples/run_wealth_advisor.py — Postgres·검색 키 등 (.env 로드 항목은 langgraph_bootstrap 참고)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/langgraph
#
# Wealth Advisor 리서치: 네이버 검색 API (웹문서 webkr) — https://developers.naver.com/products/service-api/search/search
# NAVER_CLIENT_ID=...
# NAVER_CLIENT_SECRET=...
#
# Wealth Advisor 거시 금리 리서치: Tavily — https://tavily.com
# TAVILY_API_KEY=tvly-...
#
# Wealth Advisor 세법 맥락: 국가법령정보 국세청 법령해석 목록 API — https://open.law.go.kr
# LAW_GO_KR_OC=...   # 발급 OC (target=ntsCgmExpc, type=XML · 루트 CgmExpc). 미설정 시 Wealth Advisor 실행 불가.
# 상세 링크(taxlaw.nts.go.kr) 본문은 JS 로드 → `uv sync --extra nts-law-detail` 후 `playwright install chromium`
# NTS_LAW_USE_PLAYWRIGHT_DETAIL=1   # 미설정 시 playwright 설치 여부로 자동. 0=GET만
# NTS_LAW_PLAYWRIGHT_TIMEOUT_MS=60000
# NTS_LAW_MAX_API_QUERIES=5
# NTS_LAW_FALLBACK_API_QUERIES=소득세   # 프로필 nts_law_api_queries 비었을 때만(쉼표로 여러 개)

# Langfuse 관측 — https://langfuse.com/docs/integrations/langchain
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# (구식) LANGFUSE_HOST=...  # LANGFUSE_BASE_URL 과 동일 역할
